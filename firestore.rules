rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - email: string (required)
    //   - role: string (required) - 'admin' | 'user'
    //   - status: string (required) - 'active' | 'blocked' | 'pending'
    //   - trophyLevel: number (required)
    //   - totalDrawings: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: drawings
    // Document ID: {drawingId}
    // Fields:
    //   - creatorUid: string (required)
    //   - creatorName: string (required)
    //   - creatorPhoto: string (optional)
    //   - title: string (optional)
    //   - path: list (required) - array of {lat, lng, timestamp}
    //   - likesCount: number (required)
    //   - createdAt: timestamp (required)
    //   - monthKey: string (required) - YYYY-MM
    //
    // Collection: likes
    // Document ID: {userId}_{drawingId}
    // Fields:
    //   - userId: string (required)
    //   - drawingId: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: invitations
    // Document ID: {invitationId}
    // Fields:
    //   - email: string (required)
    //   - invitedBy: string (required)
    //   - createdAt: timestamp (required)
    //   - status: string (required) - 'pending' | 'used'
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "alemacedo@gmail.com" && request.auth.token.email_verified == true);
    }

    function isActive() {
      return isAuthenticated();
      // Temporarily simplifying to debug permission issues
      // return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'trophyLevel', 'totalDrawings', 'createdAt', 'status', 'role']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string &&
             data.status in ['active', 'blocked', 'pending'] &&
             data.role in ['admin', 'user'] &&
             data.trophyLevel is number &&
             data.totalDrawings is number &&
             data.createdAt is timestamp;
    }

    function isValidDrawing(data) {
      return data.keys().hasAll(['creatorUid', 'creatorName', 'path', 'likesCount', 'createdAt', 'monthKey']) &&
             data.creatorUid == request.auth.uid &&
             data.creatorName is string &&
             data.path is list && data.path.size() < 5000 &&
             data.likesCount is number &&
             data.createdAt is timestamp &&
             data.monthKey is string && data.monthKey.matches("^\\d{4}-\\d{2}$");
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId', 'drawingId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.drawingId is string &&
             data.createdAt is timestamp;
    }

    function isValidInvitation(data) {
      return data.keys().hasAll(['email', 'invitedBy', 'createdAt', 'status']) &&
             data.email is string &&
             data.invitedBy == request.auth.uid &&
             data.createdAt is timestamp &&
             data.status in ['pending', 'used'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.role == 'user' && 
                      request.resource.data.status == 'active';
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.role == resource.data.role &&
                      request.resource.data.status == resource.data.status &&
                      request.resource.data.createdAt == resource.data.createdAt) || isAdmin();
    }

    match /drawings/{drawingId} {
      allow read: if true; // Public timeline
      allow create: if isActive() && isValidDrawing(request.resource.data);
      allow update: if isActive() && (
        // Owner update (e.g. title)
        (request.auth.uid == resource.data.creatorUid && isValidDrawing(request.resource.data)) ||
        // Like increment (Atomic update)
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']) &&
          math.abs(request.resource.data.likesCount - resource.data.likesCount) == 1 &&
          (
            // Increment: Like must exist after
            (request.resource.data.likesCount > resource.data.likesCount &&
             getAfter(/databases/$(database)/documents/likes/$(request.auth.uid + '_' + drawingId)) != null) ||
            // Decrement: Like must NOT exist after
            (request.resource.data.likesCount < resource.data.likesCount &&
             getAfter(/databases/$(database)/documents/likes/$(request.auth.uid + '_' + drawingId)) == null)
          )
        )
      ) || isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.creatorUid);
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isActive() && 
                      likeId == request.auth.uid + '_' + request.resource.data.drawingId &&
                      isValidLike(request.resource.data);
      allow delete: if isAuthenticated() && (likeId.startsWith(request.auth.uid + '_') || isAdmin());
    }

    match /invitations/{invitationId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidInvitation(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
